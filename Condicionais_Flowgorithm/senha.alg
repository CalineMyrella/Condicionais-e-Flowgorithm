algoritmo "Idade"
// Funçăo :LOPAL (Lógica de programaçăo)

// Autor : Caline Myrella
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
//Declaraçăo de variaveis

senha:literal

inicio
// Seçăo de Comandos 

   escreva ("digite a senha")
   leia (senha)
   
   se senha="acb23" entao
   
   escreval ("senha correta ")
   
   senao
   
   escreval ("senha incorreta ")
    fimse

fimalgoritmo
