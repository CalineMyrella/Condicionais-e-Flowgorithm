algoritmo "Idade"
// Funçăo :LOPAL (Lógica de programaçăo)
// Autor : Caline Myrella
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
//Declaraçăo de variaveis

idade: real

inicio
// Seçăo de Comandos 

   escreva ("Digite sua idade")
   leia (idade)
   
   se idade>=18 entao
   
   escreval ("maior de idade, pode dirigir")
   
   senao
   
   escreval ("menor de idade pode ")
    fimse

fimalgoritmo
