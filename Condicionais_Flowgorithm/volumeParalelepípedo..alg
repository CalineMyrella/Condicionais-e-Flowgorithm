algoritmo "Soma dos números"
// Funçăo : LOPAL (Lógica de Programaçăo)

//F9 (executava meu código)

// Autor :  Caline Myrella
// Data : 13/04/2026
var
 //Declaraçăo de variáveis
 
 base,altura,largura,volume,valorFinal: real
inicio
// Inicio dos dados

   escreva ("coloque o primeiro valor: ")
   leia (base)
   
   escreva ("coloque o segundo valor: ")
   leia(altura)
   
   escreva ("coloque o terceiro valor: ")
   leia (largura)
 
 //realizar a divisăo e a multiplicaçăo do peso e alturas
 valorFinal<- base * altura * largura
 
 escreval ("o valorFinal do voume", valorFinal)


fimalgoritmo
