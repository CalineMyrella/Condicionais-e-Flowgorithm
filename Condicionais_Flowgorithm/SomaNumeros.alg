algoritmo "soma dos numeros"

// Autor : Caline Myrella
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
 //Declaraçăo de variáveis
 numero1, numero2, numero3, soma: real
inicio
 //Seçăo de comandos
 
      escreva ("informe o numero1: ")
      leia(numero1)
      
      escreva ("informe o numero2: ")
      leia(numero2)
      
      escreva ("informe o numero3: ")
      leia(numero3)
      
 //realizar a soma dos tręs numeros
      
      soma<- numero1 + numero2 + numero3
      
      escreval ("valor da soma dos numeros", soma)
      

fimalgoritmo
